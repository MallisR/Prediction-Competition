R


options(repos = c(CRAN = "https://cloud.r-project.org"))
install.packages(c("readxl", "dplyr"))   # run once
library(readxl)
library(dplyr)

# Load file
df <- read_excel("raw_data/h251.xlsx")

# Check column names first
names(df)

# Build regression-ready filtered data (replace with your real column names)
reg_data <- df %>%
  select(y, x1, x2, category) %>%                  # keep only model columns
  filter(!is.na(y), !is.na(x1), !is.na(x2)) %>%   # drop rows with missing model values
  mutate(category = as.factor(category))           # categorical predictor

# Run regression
model <- lm(y ~ x1 + x2 + category, data = reg_data)
summary(model)





write.csv(reg_data, "filtered_data.csv", row.names = FALSE)